/* HEADER */
header {
  background: linear-gradient(135deg, var(--dark) 0%, #c0392b 100%);
  color: white;
  padding: 0 24px;
  position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 16px rgba(0,0,0,0.3);
}
.header-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 64px;
}
.logo { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--gold); }
nav { display: flex; gap: 16px; flex-wrap: wrap; }
nav a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 13px; font-weight: 500; transition: color 0.2s; }
nav a:hover { color: var(--gold); }

/* HERO */
.hero {
  background: linear-gradient(135deg, #c0392b 0%, #f0a500 100%);
  color: white; text-align: center; padding: 64px 24px;
}
.hero h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 12px; }
.hero p { font-size: 1.1rem; opacity: 0.9; margin-bottom: 28px; }
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.btn-outline { border: 2px solid white; color: white; padding: 12px 28px; border-radius: 50px; text-decoration: none; font-weight: 600; transition: all 0.2s; }
.btn-outline:hover { background: white; color: var(--red); }

/* CATEGORY TABS */
.cat-tabs { background: white; border-bottom: 1px solid #eee; position: sticky; top: 64px; z-index: 99; overflow-x: auto; }
.cat-tabs-inner { display: flex; max-width: 1200px; margin: 0 auto; padding: 0 16px; gap: 4px; }
.cat-tab { padding: 14px 18px; border: none; background: none; cursor: pointer; font-size: 14px; font-weight: 500; color: var(--gray); border-bottom: 3px solid transparent; white-space: nowrap; transition: all 0.2s; }
.cat-tab.active, .cat-tab:hover { color: var(--red); border-bottom-color: var(--red); }

/* PRODUCTS */
.products { max-width: 1200px; margin: 0 auto; padding: 40px 16px; }
.section { margin-bottom: 48px; display: none; }
.section.active { display: block; }
.section-title { margin-bottom: 24px; }
.section-title h2 { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--dark); }
.section-title p { color: var(--gray); margin-top: 4px; }
.product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }

/* PRODUCT CARD */
.product-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.2s; }
.product-card:hover { transform: translateY(-4px); }
.product-img { background: #f3f4f6; height: 160px; display: flex; align-items: center; justify-content: center; font-size: 64px; }
.product-info { padding: 16px; }
.product-badge { display: inline-block; background: #fff3cd; color: #856404; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; margin-bottom: 8px; }
.product-name { font-weight: 600; font-size: 15px; margin-bottom: 8px; line-height: 1.3; }
.product-price { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.price-new { color: var(--red); font-weight: 700; font-size: 18px; }
.price-old { color: var(--gray); text-decoration: line-through; font-size: 14px; }
.btn-cart {
  width: 100%; padding: 10px;
  background: var(--green); color: white;
  border: none; border-radius: 10px;
  font-size: 14px; font-weight: 600; cursor: pointer;
  transition: background 0.2s;
}
.btn-cart:hover { background: #1da851; }

/* ABOUT */
.about { background: var(--dark); color: white; padding: 60px 24px; text-align: center; }
.about h2 { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--gold); margin-bottom: 16px; }
.about p { max-width: 600px; margin: 0 auto; opacity: 0.85; line-height: 1.7; }

/* CONTACT */
.contact { max-width: 800px; margin: 0 auto; padding: 60px 24px; }
.contact h2 { font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 32px; text-align: center; }
.contact-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
.contact-card { background: white; border-radius: 16px; padding: 20px; box-shadow: var(--shadow); text-align: center; }
.contact-icon { font-size: 32px; margin-bottom: 8px; }
.contact-card h4 { font-size: 14px; color: var(--gray); margin-bottom: 4px; }
.contact-card p { font-weight: 600; font-size: 14px; }

/* FOOTER */
footer { background: var(--dark); color: rgba(255,255,255,0.6); text-align: center; padding: 20px; font-size: 13px; }
footer span { color: var(--gold); }

/* WHATSAPP FLOAT */
.wa-float {
